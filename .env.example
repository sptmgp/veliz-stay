# ─── Veliz Stay — Environment Variables ───────────────────────────────────────
# Copy this file to .env and fill in your real values
# NEVER commit .env to git

# Server
PORT=3000
NODE_ENV=production

# JWT — use a long random string (openssl rand -hex 32)
JWT_SECRET=REPLACE_WITH_32_CHAR_RANDOM_STRING

# Database — from Supabase: Settings > Database > Connection string (URI)
DATABASE_URL=postgresql://postgres:PASSWORD@db.YOURPROJECT.supabase.co:5432/postgres

# MSG91 — Indian SMS / OTP provider (msg91.com)
MSG91_AUTH_KEY=REPLACE_WITH_MSG91_AUTH_KEY
MSG91_TEMPLATE_ID=REPLACE_WITH_OTP_TEMPLATE_ID
MSG91_SENDER_ID=VELIZS

# Razorpay — razorpay.com > Settings > API Keys
RAZORPAY_KEY_ID=rzp_live_REPLACE
RAZORPAY_KEY_SECRET=REPLACE_WITH_RAZORPAY_SECRET

# Cloudinary — cloudinary.com (for property photos)
CLOUDINARY_URL=cloudinary://API_KEY:API_SECRET@CLOUD_NAME

# Admin seed account (created on first migration)
ADMIN_EMAIL=admin@velizstay.com
ADMIN_PASSWORD=CHANGE_THIS_STRONG_PASSWORD

# App URL (your Railway / custom domain)
APP_URL=https://velizstay.com
